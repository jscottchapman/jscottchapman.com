---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  /** og image path under the site root, e.g. "/og.png" */
  ogImage?: string;
  /** masthead sub-rule line; pass "" to hide it */
  tagline?: string;
}

const {
  title = 'J Scott Chapman · AI product consultant',
  description = 'J Scott Chapman is an AI product consultant who builds software end to end, stays close to the people using it, and finds out whether it actually worked.',
  ogImage = '/og-card.png',
  tagline = 'Building things, shipping them, and finding out whether they worked.',
} = Astro.props;

// On preview deploys, point canonical + OG image at the deployment's own
// domain so share cards are self-contained. Production uses the real site.
const prodOrigin = 'https://jscottchapman.com';
const deployOrigin =
  process.env.VERCEL_ENV && process.env.VERCEL_ENV !== 'production' && process.env.VERCEL_URL
    ? `https://${process.env.VERCEL_URL}`
    : prodOrigin;
const canonical = new URL(Astro.url.pathname, deployOrigin);
const ogImageUrl = new URL(ogImage, deployOrigin);
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);

const nav = [
  { href: '/work/', label: 'Work' },
  { href: '/notes/', label: 'Notes' },
  { href: '/skills/', label: 'Skills' },
  { href: '/about/', label: 'About' },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="J Scott Chapman" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@RavenviewSrvcs" />
    <meta name="twitter:creator" content="@RavenviewSrvcs" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={title} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400..700;1,6..72,400..700&family=IBM+Plex+Sans:wght@400;500;600;700&family=Caveat:wght@500;700&display=swap"
      rel="stylesheet"
    />

    <slot name="head" />
  </head>
  <body>
    <header class="masthead">
      <div class="wrap">
        <div class="row">
          <a class="brand" href="/">J Scott Chapman</a>
          <nav class="nav" aria-label="Primary">
            {nav.map((item) => (
              <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
                {item.label}
              </a>
            ))}
          </nav>
        </div>
        {tagline && (
          <div class="row under">
            <span>{tagline}</span>
            <span>Missoula, MT</span>
          </div>
        )}
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="wrap">
        <span>© 2026 J Scott Chapman · Missoula, Montana</span>
        <span class="fnav">
          <a href="/work/">Work</a>
          <a href="/notes/">Notes</a>
          <a href="/skills/">Skills</a>
          <a href="mailto:scott@ravenviewservices.com">Email</a>
        </span>
      </div>
    </footer>
  </body>
</html>
