---
import Base from '../../layouts/Base.astro';
import Share from '../../components/Share.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const notes = (await getCollection('notes')).filter((n) => !n.data.draft);
  return notes.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---

<Base
  title={`${entry.data.title} · J Scott Chapman`}
  description={entry.data.description}
  tagline=""
>
  <article class="section" style="border-top:0;padding-top:24px;">
    <div class="wrap">
      <header class="article-head">
        <a class="back-link" href="/notes/">← Notes</a>
        <span class="when">{fmt(entry.data.date)}</span>
        <h1>{entry.data.title}</h1>
        <p class="standfirst">{entry.data.description}</p>
      </header>
      <div class="prose">
        <Content />
      </div>
      <Share title={entry.data.title} />
    </div>
  </article>
</Base>
