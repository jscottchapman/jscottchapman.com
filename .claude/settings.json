      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git pull *)",
      "Bash(git branch *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(npm run build*)",
      "Bash(npm test*)",
      "Bash(npm run dev*)",
      "Bash(npm run preview*)",
      "Bash(npx playwright *)",
      "Bash(gh issue *)",
      "Bash(gh pr *)"
    ]
  }
}
